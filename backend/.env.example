# Server Configuration
PORT=5000

# MongoDB Configuration
# Replace <username>, <password>, and <cluster-url> with your MongoDB Atlas details.
# Remove < > brackets and ensure the DB name is set at the end (e.g., /job_tracker).
# Example: MONGO_URI=mongodb+srv://dbUser:strongPassword123@mycluster.mongodb.net/job_tracker?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USERNAME:aditya123@YOUR_CLUSTER_URL/jobtracker?retryWrites=true&w=majority
PORT=5000
# JWT Authentication
# Replace this with a strong, random secret key for signing tokens.
JWT_SECRET=your_jwt_super_secret_key_here

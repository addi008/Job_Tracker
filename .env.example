# =====================================================================
# CAREERFLOW ROOT ENVIRONMENT CONFIGURATION
# Copy these values into backend/.env
# =====================================================================

# Server Port
PORT=5000

# MongoDB Atlas Connection String
# 1. Replace <username> with your Atlas Database User
# 2. Replace <password> with your Database User Password (URL-encoded if special characters exist)
# 3. Replace <cluster-url> with your Cluster host (e.g. cluster0.abcde.mongodb.net)
# 4. Replace <dbname> with your database name (e.g. job_tracker)
# DO NOT leave the "<" and ">" brackets!
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority

# JWT Token Secret
# Replace with a strong secret key.
JWT_SECRET=your_jwt_super_secret_key_here
